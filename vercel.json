{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.0"
    }
  },
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.php" },
    { "src": "/build/assets/(.*)", "dest": "/public/" },
    { "src": "/assets/styles/(.*)", "dest": "/public/assets/styles/" },
    { "src": "/assets/img/(.*)", "dest": "/public/assets/img/" },
    { "src": "/assets/fonts/(.*)", "dest": "/public/assets/fonts/" }
  ]
}
